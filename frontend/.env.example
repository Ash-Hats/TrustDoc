# ============================================================================
# TrustDoc Frontend Environment Configuration (Production)
# ============================================================================
# Copy this file to .env.local and fill in with your actual values
#
# CHANGES: Standardized to VITE_AMOY_RPC_URL for Polygon Amoy and kept placeholder values for frontend env secrets.

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
# Get these from your Supabase project settings:
# https://app.supabase.com/project/[your-project-id]/settings/api

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================================
# BLOCKCHAIN CONFIGURATION
# ============================================================================
# Polygon Amoy RPC URL (get from Alchemy, Infura, or QuickNode)

VITE_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your-api-key
VITE_MIN_PRIORITY_FEE_GWEI=30

# Smart Contract Address (deployed on Polygon Amoy)
VITE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Your app's deployed URL (used for OAuth callbacks)
VITE_APP_ORIGIN=http://localhost:5173

# IPFS Gateway URL (for fetching documents from IPFS)
VITE_IPFS_GATEWAY_URL=https://gateway.pinata.cloud/ipfs/

# Required: backend relay endpoint for Pinata uploads (keeps secrets off frontend)
# When deployed on Vercel with this repo setup, use `/api/pinata-upload`.
VITE_PINATA_UPLOAD_ENDPOINT=/api/pinata-upload

# Optional local-dev fallback API origin when running Vite and API runtime separately.
# Keep default for most setups.
VITE_DEV_API_ORIGIN=http://127.0.0.1:3000

# Optional explicit backend/API origin for server-protected RBAC endpoints.
VITE_API_ORIGIN=

# Do not expose Pinata JWT in frontend env.
VITE_PINATA_GATEWAY=https://gateway.pinata.cloud

# ============================================================================
# ANALYTICS & MONITORING (Optional)
# ============================================================================

# Sentry DSN (for error tracking)
VITE_SENTRY_DSN=

# Google Analytics ID
VITE_GA_ID=

# ============================================================================
# FEATURE FLAGS (Optional)
# ============================================================================

# Enable/disable features
VITE_ENABLE_REALTIME_SYNC=true
VITE_ENABLE_WALLET_MANAGEMENT=true
VITE_ENABLE_DOCUMENT_SHARING=true
VITE_ENABLE_AUDIT_LOGS=true

# ============================================================================
# API LIMITS & CONFIGURATION (Production)
# ============================================================================

# Rate limiting
VITE_API_RATE_LIMIT_PER_MINUTE=60
VITE_DOCUMENT_UPLOAD_LIMIT_MB=100

# Session timeout (milliseconds)
VITE_SESSION_TIMEOUT_MS=1800000

# Max document retention (days)
VITE_DOC_RETENTION_DAYS=2555

# ============================================================================
# DEPLOYMENT ENVIRONMENT
# ============================================================================

# Set to 'production' for production builds
VITE_ENV=development

# Enable debug mode (set to false in production)
VITE_DEBUG=false
