{
  "buildCommand": "cd frontend && npm run build",
  "installCommand": "npm install",
  "framework": "vite",
  "outputDirectory": "frontend/dist",
  "nodeVersion": "20.x",
  "regions": ["sfo1"],
  "env": {
    "VITE_SUPABASE_URL": {
      "description": "Supabase project URL",
      "required": true
    },
    "SUPABASE_URL": {
      "description": "Server-side Supabase project URL",
      "required": true
    },
    "VITE_SUPABASE_ANON_KEY": {
      "description": "Supabase anonymous key",
      "required": true
    },
    "SUPABASE_ANON_KEY": {
      "description": "Server-side Supabase anonymous key",
      "required": true
    },
    "SUPABASE_SERVICE_ROLE_KEY": {
      "description": "Supabase service role key for privileged backend RBAC APIs",
      "required": true
    },
    "VITE_AMOY_RPC_URL": {
      "description": "Polygon Amoy RPC URL",
      "required": true
    },
    "VITE_CONTRACT_ADDRESS": {
      "description": "Smart contract address on Polygon Amoy",
      "required": true
    },
    "VITE_APP_ORIGIN": {
      "description": "Application origin URL",
      "required": true
    },
    "APP_ORIGIN": {
      "description": "Server-side application origin URL",
      "required": true
    },
    "TRUSTDOC_ALLOWED_ORIGINS": {
      "description": "Comma-separated trusted origins for API CSRF/origin checks",
      "default": "http://localhost:5173,http://127.0.0.1:5173"
    },
    "VITE_PINATA_UPLOAD_ENDPOINT": {
      "description": "Upload relay endpoint for Pinata metadata",
      "required": true,
      "default": "/api/pinata-upload"
    },
    "VITE_PINATA_GATEWAY": {
      "description": "Pinata IPFS gateway URL",
      "required": true
    },
    "PINATA_JWT": {
      "description": "Server-side Pinata JWT used by /api/pinata-upload",
      "required": true
    },
    "PINATA_GATEWAY": {
      "description": "Server-side Pinata gateway base URL",
      "required": true
    },
    "VITE_ENV": {
      "description": "Environment (development/production)",
      "default": "production"
    },
    "VITE_DEBUG": {
      "description": "Debug mode",
      "default": "false"
    }
  },
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=()"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "github": {
    "enabled": false
  }
}
