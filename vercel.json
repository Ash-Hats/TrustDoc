{
  "buildCommand": "cd frontend && npm run build",
  "installCommand": "npm install",
  "framework": "vite",
  "outputDirectory": "frontend/dist",
  "nodeVersion": "20.x",
  "regions": ["sfo1"],
  "env": {
    "VITE_SUPABASE_URL": {
      "description": "Supabase project URL",
      "required": true
    },
    "VITE_SUPABASE_ANON_KEY": {
      "description": "Supabase anonymous key",
      "required": true
    },
    "VITE_AMOY_RPC_URL": {
      "description": "Polygon Amoy RPC URL",
      "required": true
    },
    "VITE_CONTRACT_ADDRESS": {
      "description": "Smart contract address on Polygon Amoy",
      "required": true
    },
    "VITE_APP_ORIGIN": {
      "description": "Application origin URL",
      "required": true
    },
    "VITE_PINATA_JWT": {
      "description": "Pinata JWT token for IPFS",
      "required": false
    },
    "VITE_PINATA_GATEWAY": {
      "description": "Pinata IPFS gateway URL",
      "required": false
    },
    "VITE_ENV": {
      "description": "Environment (development/production)",
      "default": "production"
    },
    "VITE_DEBUG": {
      "description": "Debug mode",
      "default": "false"
    }
  },
  "functions": {
    "frontend/**/*.js": {
      "maxDuration": 60
    }
  },
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=()"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "github": {
    "enabled": false
  }
}
